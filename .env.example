# Hey! Before running this project, you need to set up your API keys.
# Just copy this file, rename it to .env, and paste your real credentials below.
# Never share your .env file publicly — it's already in .gitignore so you're safe.

# Your BrowserStack login — grab these from your BrowserStack account settings
BROWSERSTACK_USERNAME=your_browserstack_username
BROWSERSTACK_ACCESS_KEY=your_browserstack_access_key

# Your RapidAPI key — sign up at rapidapi.com and subscribe to Google Translate API
RAPIDAPI_KEY=your_rapidapi_key_here